# Database connection (PostgreSQL)
# Format: "postgresql://user:password@host:5432/dbname?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/messenger?schema=public"

# JWT secret for authentication tokens (REQUIRED - change this in production)
JWT_SECRET="dev-secret-key-change-in-production"

# Message encryption key (REQUIRED - must be unique and strong)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY="your-64-character-hex-string-here"

# Cloudinary URL for avatar uploads (REQUIRED)
# Sign up free at https://cloudinary.com and get your URL from the Dashboard
# Format: "cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Port for the server (default: 4000)
PORT=4000

# Allowed CORS origin (comma-separated for multiple)
# In production with same-origin serving, this is not needed.
# For separate client/server setups, set to the client URL.
# Examples: "https://myapp.com", "https://myapp.com,https://admin.myapp.com"
CLIENT_ORIGIN="http://localhost:5173"

# Node environment
# Set to "production" for production builds
NODE_ENV=development
